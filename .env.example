# ─────────────────────────────────────────────────────────────────────────────
#  Bangalore Transit Digital Twin — Environment Configuration
#  Copy this to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── GCP ──────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-south1
GCS_BUCKET=bangalore-transit-twin-prod
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# Topic names
TOPIC_VEHICLE_POSITIONS=vehicle-positions
TOPIC_TRIP_UPDATES=trip-updates
TOPIC_SERVICE_ALERTS=service-alerts
TOPIC_FLINK_DELAYS=flink-delay-output
TOPIC_FLINK_BUNCHING=flink-bunching-alerts

# ── GTFS Data Sources ─────────────────────────────────────────────────────────
# BMTC GTFS Static (check: https://bmtcwebportal.pascos.in/bmtc/)
BMTC_GTFS_STATIC_URL=https://bmtcwebportal.pascos.in/gtfs/bmtc_gtfs.zip
# BMTC GTFS-RT (vehicle positions)
BMTC_GTFS_RT_VEHICLE_POSITIONS_URL=https://bmtcwebportal.pascos.in/gtfs-rt/vehiclePositions
BMTC_GTFS_RT_TRIP_UPDATES_URL=https://bmtcwebportal.pascos.in/gtfs-rt/tripUpdates
# Namma Metro (Open Transit Data India)
NAMMA_METRO_GTFS_RT_URL=https://otd.delhi.gov.in/api/realtime/VehiclePositions.pb
# Fallback: OTD India unified feed
OTD_API_KEY=your-otd-api-key

# ── Weather ───────────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your-openweather-api-key
WEATHER_CITY_ID=1277333  # Bangalore OpenWeather city ID
WEATHER_POLL_INTERVAL_SEC=600

# ── Storage (local dev uses MinIO, prod uses GCS) ──────────────────────────────
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=transit-twin-local

# ── MLflow ─────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=bangalore-transit-eta

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_TTL_VEHICLE_POSITIONS=60     # seconds
REDIS_TTL_ETA_PREDICTIONS=30

# ── Serving API ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-production
API_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
WEBSOCKET_MAX_CONNECTIONS=500

# ── LLM / RAG ──────────────────────────────────────────────────────────────────
MILVUS_URI=http://localhost:19530
VLLM_MODEL=mistralai/Mistral-7B-Instruct-v0.3
VLLM_BASE_URL=http://localhost:8001/v1

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_WEATHER_FEATURES=true
ENABLE_LLM_AGENT=false
ENABLE_DVR_REPLAY=true
LOG_LEVEL=INFO